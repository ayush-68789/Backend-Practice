<% layout('Students/layouts/boilerplate.ejs') %>
<%- include('partials/navbar') %>
    <div class="row">
        <% for(let x of data){ %>
            <div class="col-2">
                <div class="card" style="width: 18rem;">
                    <img src="<%=x.img%>" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Name : <%=x.name%></h5>
                        <p class="card-text">Roll : <%=x.roll%></p>
                        <p class="card-text">Section : <%=x.section%></p>
                        <a href="/students/<%=x.id%>" class="btn btn-primary">View Student</a>
                        <form action="/students/<%=x.id%>?_method=DELETE" method="POST">
                            <button class="submit btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>
    </div>